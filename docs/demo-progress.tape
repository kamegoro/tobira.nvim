Output docs/demo-progress.gif

Set Shell "zsh"
Set FontSize 15
Set Width 1200
Set Height 580
Set Theme "Catppuccin Mocha"
Set Padding 20
Set TypingSpeed 60ms
Set CursorBlink false

# ── Boot ──────────────────────────────────────────────────────────────────────
Hide
Type "cd ~/kame/tobira.nvim && nvim -u docs/demo-init.lua docs/demo.lua"
Enter
Sleep 3s
Show

# ── Open progress tree ────────────────────────────────────────────────────────
Sleep 400ms
Type ":TobiraProgress"
Enter
Sleep 5000ms
