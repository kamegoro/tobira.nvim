Output docs/demo-guide.gif

Set Shell "zsh"
Set FontSize 18
Set Width 1920
Set Height 720
Set Theme "Catppuccin Mocha"
Set Padding 20
Set TypingSpeed 60ms
Set CursorBlink false

# ── Boot ──────────────────────────────────────────────────────────────────────
Hide
Type "cd ~/kame/tobira.nvim && nvim -u docs/demo-init.lua docs/demo.lua"
Enter
Sleep 3s
Show

# ── Open guide panel ─────────────────────────────────────────────────────────
Sleep 400ms
Type ":TobiraGuide"
Enter
Sleep 5000ms
